# ============================================================
# Scryvex Pro — Variables de entorno
# Copiar este archivo como .env y completar los valores
# ============================================================

# Token de seguridad para el webhook de auto-update de Watchtower
# Generá uno con: openssl rand -hex 32
WATCHTOWER_HTTP_API_TOKEN=cambia_esto_por_un_token_seguro

# DNS personalizado (opcional — por defecto usa Cloudflare 1.1.1.1 y Google 8.8.8.8)
# SCRYPTED_DNS_SERVER_0=192.168.1.1
# SCRYPTED_DNS_SERVER_1=8.8.8.8

# Polling de updates de Watchtower (true = activo)
WATCHTOWER_HTTP_API_PERIODIC_POLLS=true
