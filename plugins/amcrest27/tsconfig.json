{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2021",
        "resolveJsonModule": true,
        "moduleResolution": "node",
        "ignoreDeprecations": "6.0",
        "esModuleInterop": true,
        "sourceMap": true,
        "baseUrl": ".",
        "paths": {
            "@scrypted/sdk": [
                "./node_modules/@scrypted/sdk"
            ],
            "@scrypted/common/*": [
                "./node_modules/@scrypted/common/*"
            ],
            "@scrypted/sdk/*": [
                "./node_modules/@scrypted/sdk/dist/src/*"
            ]
        },
        "skipLibCheck": true,
        "noImplicitAny": false,
        "strict": false,
        "types": [
            "node"
        ],
        "lib": [
            "es2022",
            "esnext.disposable",
            "dom"
        ]
    },
    "include": [
        "src/**/*"
    ]
}
