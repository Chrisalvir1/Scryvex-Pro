{
    "compilerOptions": {
        "module": "es2022",
        "target": "ES2021",
        "resolveJsonModule": true,
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "sourceMap": true,
        "skipLibCheck": true,
        "noImplicitAny": false,
        "strict": false,
        "types": [
            "node"
        ],
        "lib": [
            "es2022",
            "esnext.disposable",
            "dom"
        ]
    },
    "include": [
        "src/**/*",
        "../../common/src/**/*",
        "../../server/src/**/sleep.ts",
        "../../server/src/**/media-helpers.ts"
    ]
}
