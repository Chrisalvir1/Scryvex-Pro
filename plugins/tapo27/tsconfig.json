{
    "compilerOptions": {
        "module": "Node16",
        "target": "ES2021",
        "resolveJsonModule": true,
        "moduleResolution": "Node16",
        "esModuleInterop": true,
        "strict": false,
        "sourceMap": true,
        "skipLibCheck": true,
        "noImplicitAny": false,
        "types": [
            "node"
        ],
        "lib": [
            "es2022",
            "esnext.disposable",
            "dom"
        ]
    },
    "include": [
        "src/**/*"
    ]
}
